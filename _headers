/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: frame-ancestors 'none'

# App entry — ABSOLUTELY no caching anywhere (browser, CDN, proxy).
# This is the only safe default for a single-page app: index.html must always
# be fresh because it references the versioned bundle paths.
/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/listing.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/listing
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# Dashboard / Lister pages (Session 3 of MPA refactor) — protected pages
# behind auth, but the HTML shell still needs no-cache so the version stamp
# is fresh on every visit.
/dashboard.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/dashboard
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/lister.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/lister
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# Browse listings page (Session 5 of MPA refactor) — public, crawlable.
/browse.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/browse
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# JS and CSS — must revalidate every visit. With ETag/If-None-Match the
# server returns 304 when unchanged (fast) but always serves new content
# the moment it changes.
/app.js
  Cache-Control: no-cache, must-revalidate
  CDN-Cache-Control: no-store

/common.js
  Cache-Control: no-cache, must-revalidate
  CDN-Cache-Control: no-store

/tenant-profile.js
  Cache-Control: no-cache, must-revalidate
  CDN-Cache-Control: no-store

/app.css
  Cache-Control: no-cache, must-revalidate
  CDN-Cache-Control: no-store

# Version stamp — the page polls this to detect new deploys, so it must
# never be cached or update notifications stop working.
/version.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store
  Cloudflare-CDN-Cache-Control: no-store

# Service worker — MUST always be fresh, otherwise users are stuck on the
# old worker which serves the old cached files. Browsers special-case sw.js
# anyway, but be explicit.
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Service-Worker-Allowed: /
  CDN-Cache-Control: no-store
